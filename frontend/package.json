{
  "name": "nuria-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-dev-ready.js",
    "dev": "next dev -p 3000",
    "dev:clean": "npm run clean && next dev -p 3000",
    "build": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "reinstall": "node -e \"const fs=require('fs');['.next','node_modules','package-lock.json','next-env.d.ts'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\" && npm install"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.10",
    "@types/node": "22.15.30",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.21",
    "lucide-react": "1.21.0",
    "negotiator": "^1.0.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "postcss": "8.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  },
  "devDependencies": {
    "eslint": "9.28.0",
    "eslint-config-next": "16.2.9"
  }
}
