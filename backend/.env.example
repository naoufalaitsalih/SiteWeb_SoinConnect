PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="change_me_in_production"
JWT_EXPIRES_IN=8h
# Mot de passe admin officiel (utilisé par seed + démarrage serveur)
# Laisser vide ou Admin@2026 pour l'identifiant officiel
SEED_ADMIN_PASSWORD="Admin@2026"
# Logs détaillés auth (email, bcrypt, raison échec) — true en dev
AUTH_DEBUG="true"
# Secret route temporaire GET /api/admin/debug/check-admin?secret=...
DEBUG_SECRET="change_me_debug_secret_before_production"
