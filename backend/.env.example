PORT=4000
NODE_ENV=development
# Mot de passe vide (root sans mot de passe) :
DATABASE_URL="mysql://root:@localhost:3306/siteweb_soinsconnect"
# Avec mot de passe :
# DATABASE_URL="mysql://root:VOTRE_MOT_DE_PASSE@localhost:3306/siteweb_soinsconnect"
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3005
# Générer avec: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_48"
JWT_EXPIRES_IN=8h
# Mot de passe admin initial (seed uniquement — ne pas utiliser en production)
SEED_ADMIN_PASSWORD="ChangeMeBeforeProduction!"
