@baseUrl = https://soinsconnect-api.onrender.com
@adminEmail = admin@soinsconnect.ma
@adminPassword = Admin@2026

### Health
GET {{baseUrl}}/api/health

### Care requests — list
GET {{baseUrl}}/api/requests

### Care requests — create
POST {{baseUrl}}/api/requests
Content-Type: application/json

{
  "fullName": "Test Patient",
  "phone": "0612345678",
  "email": "test@example.com",
  "address": "12 Rue Test, Casablanca",
  "careType": "Soins infirmiers",
  "description": "Test demande via test-api.http",
  "requestedDate": "2026-06-25",
  "requestedTime": "10:00",
  "isUrgent": false
}

### Admin login
# @name adminLogin
POST {{baseUrl}}/api/admin/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Public log event
POST {{baseUrl}}/api/logs
Content-Type: application/json

{
  "eventType": "page_view",
  "pageUrl": "/fr",
  "userRole": "visitor",
  "locale": "fr"
}

### Admin logs — list
GET {{baseUrl}}/api/admin/logs
Authorization: Bearer {{adminLogin.response.body.data.token}}

### Admin logs — delete by ids
DELETE {{baseUrl}}/api/admin/logs
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.data.token}}

{
  "ids": [1]
}
