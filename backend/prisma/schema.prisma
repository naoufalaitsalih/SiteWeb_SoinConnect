generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CareRequest {
  id            Int      @id @default(autoincrement())
  fullName      String   @map("full_name") @db.VarChar(255)
  phone         String   @db.VarChar(50)
  email         String?  @db.VarChar(255)
  address       String   @db.Text
  careType      String   @map("care_type") @db.VarChar(100)
  description   String?  @db.Text
  requestedDate DateTime @map("requested_date") @db.Date
  requestedTime String   @map("requested_time") @db.VarChar(10)
  isUrgent      Boolean  @default(false) @map("is_urgent")
  status        String   @default("pending") @db.VarChar(50)
  adminNotes    String?  @map("admin_notes") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("care_requests")
}

model Admin {
  id        Int       @id @default(autoincrement())
  firstName String?   @map("first_name")
  lastName  String?   @map("last_name")
  email     String    @unique
  password  String
  role      String    @default("super_admin")
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}

model EventLog {
  id          Int      @id @default(autoincrement())
  eventType   String   @map("event_type") @db.VarChar(100)
  pageUrl     String?  @map("page_url") @db.VarChar(500)
  elementName String?  @map("element_name") @db.VarChar(255)
  userRole    String   @default("visitor") @map("user_role") @db.VarChar(20)
  sessionId   String?  @map("session_id") @db.VarChar(64)
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  browser     String?  @db.VarChar(100)
  os          String?  @db.VarChar(100)
  deviceType  String?  @map("device_type") @db.VarChar(50)
  referrer    String?  @db.VarChar(500)
  locale      String?  @db.VarChar(10)
  country     String?  @db.VarChar(100)
  city        String?  @db.VarChar(100)
  timezone    String?  @db.VarChar(100)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([eventType])
  @@map("event_logs")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   @db.VarChar(100)
  userId     Int?     @map("user_id")
  userEmail  String?  @map("user_email") @db.VarChar(255)
  userRole   String?  @map("user_role") @db.VarChar(50)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  resource   String?  @db.VarChar(255)
  resourceId String?  @map("resource_id") @db.VarChar(50)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}
